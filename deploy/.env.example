# NuFi Egress-Audit 배포 환경변수 (deploy/.env 로 복사해 사용).
#   cp deploy/.env.example deploy/.env

# 게이트웨이 호스트 노출 포트.
GATEWAY_PORT=4000

# 이미지 태그(에어갭 번들 시 build-bundle.sh 와 일치시킬 것).
NUFI_TAG=0.0.2-dev

# NER 백엔드: gazetteer(기본·온프렘·외부호출 0) | transformers | auto
# 에어갭 코어는 gazetteer 권장. transformers 는 heavy 오버레이에서 사용.
EGRESS_NER_BACKEND=gazetteer

# private 백엔드 강제 다운(데모: public 폴백 경로 시연). 1=강제, 0=정상.
EGRESS_PRIVATE_DOWN=0
