#!/usr/sbin/nft -f
# NuFi Egress Enforcement — 생성물, 직접 편집 금지.
# policy_src=routing.yaml+policy.yaml  source=enforcement.rule_builder
# kind=enforce fail_mode=open table=inet/nufi_egress
add table inet nufi_egress
delete table inet nufi_egress
table inet nufi_egress {
	set public_dst {
		type ipv4_addr . inet_service
		comment "public LLM 목적지 (routing.yaml egress_class: public)"
		elements = { 203.0.113.10 . 443, 203.0.113.20 . 443 }
	}
	chain output {
		type filter hook output priority 0; policy accept;
		# 1) 게이트웨이 화이트리스트 (선적용 — 항상 drop 보다 먼저)
		meta skuid 1000 ip daddr . th dport @public_dst accept comment "gateway uid 1000"
		socket cgroupv2 level 2 "system.slice/nufi-gateway.service" ip daddr . th dport @public_dst accept comment "gateway cgroup"
		# 2) 그 외 출처 → public 목적지 = 우회 → drop + 로그
		ip daddr . th dport @public_dst log prefix "nufi-egress-block " drop
	}
}
